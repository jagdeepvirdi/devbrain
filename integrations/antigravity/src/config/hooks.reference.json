{
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "~/.gemini/config/scripts/session-start.sh",
          "timeout": 30
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "~/.gemini/config/scripts/session-end.sh",
          "timeout": 60
        }
      ]
    }
  ]
}
