# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://devbrain:devbrain@localhost:5432/devbrain

# ── Ollama — native install, running directly on host GPU ─────────────────
# Local dev: localhost works fine
# Inside Docker app container: use host.docker.internal
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=mistral

# ── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────
# JWT_SECRET: min 32 chars — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-random-32-char-string

# AUTH_PASSWORD: required in production (NODE_ENV=production).
# Leave blank for dev mode (auto-issues token, no login gate).
AUTH_PASSWORD=

# FORCE_HTTPS: set to true behind a reverse proxy (Caddy, nginx) to enforce HTTPS.
# Adds HSTS header and redirects HTTP → HTTPS based on X-Forwarded-Proto.
FORCE_HTTPS=false

# ── Claude API (optional — only used when USE_CLAUDE=true) ────────────────
ANTHROPIC_API_KEY=
USE_CLAUDE=false

# ── Docker Compose credentials (copy relevant vars to .env.docker) ────────
# POSTGRES_USER=devbrain
# POSTGRES_DB=devbrain
# POSTGRES_PASSWORD=change-me-in-production  # CHANGE THIS
